# Soniox Live Translate — Environment Variables
# Copy this file to .env (never commit .env to git) and fill in the values.

# ── Soniox API ───────────────────────────────────────────────────────────────
# Required for STT + translation + TTS.  Get yours at https://console.soniox.com
SONIOX_API_KEY=your_soniox_api_key_here

# ── Sentry Error Monitoring ───────────────────────────────────────────────────
# Optional.  Create a project at https://sentry.io → Settings → Projects → DSN.
# Leave blank (or remove) to disable Sentry completely — the app runs fine
# without it.
#
# IMPORTANT: never commit a real DSN to the repository.
SENTRY_DSN=

# Sentry environment tag — shows up in the Sentry dashboard.
# Common values: production, staging, development
SENTRY_ENVIRONMENT=development

# Override the release version sent to Sentry.
# Defaults to: soniox-live-translate@<APP_VERSION> (Python) or the package
# version (Electron).  Set this in CI to the exact git tag/commit hash.
# SENTRY_RELEASE=soniox-live-translate@0.4.1

# Fraction of requests to trace for performance monitoring (0.0 – 1.0).
# 0.1 = 10 %.  Set to 0 to disable performance monitoring entirely.
# SENTRY_TRACES_RATE=0.1

# Set to 0 to disable Sentry even if SENTRY_DSN is configured.
# SENTRY_ENABLED=1

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# These are the browser-side equivalents.  Vite only injects VITE_* variables.
# Create frontend/.env (also ignored by git) for frontend-specific overrides.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
# VITE_APP_VERSION=0.4.1
